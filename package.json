{
  "name": "voice-caller",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Schedule natural-sounding calls to local retailers asking whether a product (e.g. Pokémon) arrived.",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "start": "tsx src/server.ts",
    "build": "echo 'no build step — runs via tsx'",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx src/db/migrate.ts",
    "db:seed": "tsx src/db/seed.ts",
    "db:import-zones": "tsx src/db/import-zones.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@hono/node-server": "^1.13.7",
    "@libsql/client": "^0.14.0",
    "drizzle-orm": "^0.38.4",
    "hono": "^4.6.16",
    "imapflow": "^1.4.0",
    "jose": "^5.9.6",
    "tsx": "^4.19.2",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.6",
    "@types/ws": "^8.5.13",
    "drizzle-kit": "^0.30.2",
    "typescript": "^5.7.3"
  }
}
